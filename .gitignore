# Loose reference assets at the repo root (font source zips, design refs,
# raw photos) — these aren't part of the app. The leading "/" anchors the
# pattern to the repo root so files in subdirs (next-app/public, etc.) are
# unaffected.
/*.zip
/*.jpg
/*.jpeg
/*.png

# Raw media sources (654MB vecteezy originals) — optimized copies live in next-app/public/landing/
/Resources/
/*.mov
/*.mp4

# 3D model staging folder (large raw .glb + zips). Synced to Supabase
# Storage via `npm run sync:3d`; never committed. Optimized models live
# in the models-3d bucket, not git.
/3D MODELS/
**/*.glb
**/*.zip

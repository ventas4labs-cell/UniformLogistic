# ─── Supabase ─────────────────────────────────────────────────────────
# Project: Uniform logistic (ooszrspxtxoucngvxvsq) — get values from
# https://supabase.com/dashboard/project/ooszrspxtxoucngvxvsq/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://ooszrspxtxoucngvxvsq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (server-only). Bypasses RLS — keep out of client code.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (voice dictation, Phase 1+) ────────────────────────────
# Used by /api/admin/stock/voice-parse and /api/admin/products/voice-parse.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── OpenAI (Whisper STT fallback, Phase 4) ───────────────────────────
# Only required for browsers without window.SpeechRecognition (Firefox).
# Used by /api/admin/stock/voice-transcribe. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── App URL (optional, used for OAuth callbacks) ────────────────────
# NEXT_PUBLIC_SITE_URL=http://localhost:3001
